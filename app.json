{
  "expo": {
    "name": "LinkUp",
    "slug": "linkup",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "linkup",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#8A2BE2"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#8A2BE2",
          "sounds": [
            "./assets/notification-sound.wav"
          ]
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "LinkUp a besoin d'accéder à vos photos pour créer des publications et stories.",
          "cameraPermission": "LinkUp a besoin d'accéder à votre caméra pour prendre des photos."
        }
      ]
    ],
    "experiments": {
      "tsconfigPaths": true
    },
    "newArchEnabled": true,
    "android": {
      "package": "com.linkup.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#8A2BE2"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.linkup.app"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d66dd5a7-307f-4c48-b450-e057de7bd15e"
      }
    },
    "owner": "nicemank"
  }
}
