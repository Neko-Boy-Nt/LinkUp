{
  "expo": {
    "name": "LinkUp",
    "slug": "linkup",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "linkup",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#8A2BE2"
    },
    "assetBundlePatterns": ["**/*"],
    "plugins": ["expo-router"],
    "experiments": {
      "tsconfigPaths": true
    },
    "newArchEnabled": true
  },
  "plugins": [
    [
      "expo-notifications",
      {
        "icon": "./assets/notification-icon.png",
        "color": "#8A2BE2",
        "sounds": ["./assets/notification-sound.wav"]
      }
    ]
  ]
}
